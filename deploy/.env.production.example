# AvtoMakon — PRODUCTION .env namunasi
# Serverda /opt/avtomakon/.env nomi bilan saqlang va __...__ joylarini to'ldiring.

APP_ENV=production
APP_PORT=8000
APP_NAME=AvtoMakon

# --- PostgreSQL (serverda lokal) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=avtomakon
DB_PASSWORD=__KUCHLI_DB_PAROL__
DB_NAME=avtomakon
DB_SSL_MODE=disable
DB_MAX_CONNS=25

# --- Redis (ixtiyoriy; bo'lmasa backend baribir ishlaydi) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- JWT (kamida 32 belgi!) — generatsiya: openssl rand -base64 48 ---
JWT_SECRET=__64_BELGILI_TASODIFIY_MAXFIY_KALIT__
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# --- MinIO (serverda lokal) ---
# MINIO_ACCESS_KEY = minio.service dagi MINIO_ROOT_USER bilan bir xil
# MINIO_SECRET_KEY = minio.service dagi MINIO_ROOT_PASSWORD bilan bir xil
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=avtomakon
MINIO_SECRET_KEY=__CHANGE_ME_STRONG_MINIO_PAROL__
MINIO_BUCKET=avtomakon
MINIO_USE_SSL=false
# Domeningiz — avatar/rasm/fayllar shu manzil orqali ko'rsatiladi
MINIO_PUBLIC_URL=https://api.avtomakon.uz

# --- Boshqa ---
CORS_ALLOWED_ORIGINS=*
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
