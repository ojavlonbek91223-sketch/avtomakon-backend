# Server
APP_ENV=development
APP_PORT=8000
APP_NAME=AvtoMakon

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=avtomakon
DB_PASSWORD=avtomakon_dev_password
DB_NAME=avtomakon
DB_SSL_MODE=disable
DB_MAX_CONNS=25

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT (production'da kuchli random qiymat qo'ying)
JWT_SECRET=change-me-to-a-long-random-secret-key-at-least-32-bytes
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# MinIO (S3-compatible)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=avtomakon
MINIO_SECRET_KEY=avtomakon_dev_password
MINIO_BUCKET=avtomakon
MINIO_USE_SSL=false

# CORS
CORS_ALLOWED_ORIGINS=*

# Rate limit
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Firebase (push)
FIREBASE_CREDENTIALS_PATH=./firebase-admin.json

# SMS (Eskiz yoki Playmobile - O'zbekiston)
SMS_PROVIDER=eskiz
SMS_API_URL=https://notify.eskiz.uz/api
SMS_API_TOKEN=

# Sentry (xato monitoring, ixtiyoriy)
SENTRY_DSN=
